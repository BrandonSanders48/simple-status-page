# Admin credentials
APP_USERNAME=admin
APP_PASSWORD=changeme

# Set to "false" to disable the login requirement entirely (overrides the in-app toggle)
APP_AUTH_REQUIRED=true

# Required in production: random secret used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# Where SQLite data and uploads are stored (defaults to ./data locally, /data in Docker)
DATA_DIR=./data
