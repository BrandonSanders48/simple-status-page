# Block sensitive data files from direct browser access.
# AJAX endpoints (status_ajax.php, rss_ajax.php, etc.) remain reachable.

# Config — contains SMTP credentials and auth settings
<Files "configuration.json">
    Order deny,allow
    Deny from all
</Files>

# Subscriber email list
<Files "subscriptions.csv">
    Order deny,allow
    Deny from all
</Files>

# Internal service state cache (not needed by the browser directly)
<Files "service_status.json">
    Order deny,allow
    Deny from all
</Files>

# Cron script — should only run server-side, never via HTTP
<Files "status_check_and_notify.php">
    Order deny,allow
    Deny from all
</Files>
